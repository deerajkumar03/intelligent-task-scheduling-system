{
  "name": "distributed-intelligent-scheduler-backend",
  "version": "1.0.0",
  "description": "Distributed Intelligent Task Scheduling System",
  "main": "server.js",

  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "worker:cpu": "set WORKER_TYPE=cpu&& node workers/worker.js",
    "worker:io": "set WORKER_TYPE=io&& node workers/worker.js",
    "workers": "pm2 start ecosystem.config.js",
    "reset": "node resetSystem.js"
  },

  "keywords": [
    "distributed-systems",
    "scheduler",
    "socketio",
    "workers",
    "orchestration"
  ],

  "author": "Deeraj",
  "license": "ISC",
  "type": "commonjs",

  "dependencies": {
    "bullmq": "^5.71.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "ioredis": "^5.10.1",
    "mongoose": "^8.18.0",
    "multer": "^2.1.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "uuid": "^13.0.0"
  },

  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}